// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "languages": {
    "Plain Text": {
      "show_edit_predictions": false
    }
  },
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": false
    },
    "provider": "copilot"
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "preview_tabs": {
    "enable_preview_from_project_panel": false,
    "enabled": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "gutter": {
    "min_line_number_digits": 0,
    "bookmarks": true,
    "line_numbers": true
  },
  "terminal": {
    "shell": "system",
    "show_count_badge": true,
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "icon_theme": "Material Icon Theme",
  "project_panel": {
    "indent_guides": {
      "show": "always"
    },
    "git_status_indicator": true,
    "bold_folder_labels": true,
    "indent_size": 15.0,
    "folder_icons": false,
    "file_icons": true,
    "dock": "left"
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "buffer_font_family": "Cartograph CF",
  "show_edit_predictions": false,
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 18.0,
  "theme": {
    "mode": "system",
    "light": "Matugen Light",
    "dark": "Matugen Dark",
  },
}
