#!/bin/bash
# Premium Quickshell Theme Switcher Script for illogical-impulse / ii-vynx
# Can be run as: switch-theme [theme] OR run without arguments for interactive selection.

THEME_DIR="$HOME/.config/quickshell"
TARGET="$THEME_DIR/ii"
REFRESH_SCRIPT="$HOME/.config/hypr/custom/scripts/refresh-quickshell.sh"

# Define available themes
declare -A THEME_MAP
THEME_MAP["pacman-v2"]="$THEME_DIR/themes/pacman-v2"
THEME_MAP["pacman"]="$THEME_DIR/themes/pacman"
THEME_MAP["vynx"]="$THEME_DIR/themes/vynx"
THEME_MAP["vynx-official"]="$THEME_DIR/ii_vynx_official"

# Styling colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[1;36m'
NC='\033[0m' # No Color

show_menu() {
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN}     Quickshell Theme Switcher    ${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "Select a theme to apply:"
    echo ""
    
    local keys=("pacman-v2" "pacman" "vynx" "vynx-official")
    for i in "${!keys[@]}"; do
        local key="${keys[$i]}"
        local path="${THEME_MAP[$key]}"
        local status=""
        
        # Check if currently active
        if [ -L "$TARGET" ] && [ "$(readlink -f "$TARGET")" = "$(readlink -f "$path")" ]; then
            status=" ${GREEN}[Active]${NC}"
        fi
        
        echo -e "  $((i+1))) ${BLUE}$key${NC}$status"
    done
    echo ""
    echo -e "  q) Exit"
    echo ""
    read -rp "Enter choice [1-${#keys[@]}]: " choice
    
    if [[ "$choice" =~ ^[1-4]$ ]]; then
        apply_theme "${keys[$((choice-1))]}"
    elif [[ "$choice" = "q" ]]; then
        echo "Exiting..."
        exit 0
    else
        echo -e "${RED}Invalid choice!${NC}"
        exit 1
    fi
}

apply_theme() {
    local theme="$1"
    local source="${THEME_MAP[$theme]}"
    
    if [ -z "$source" ]; then
        echo -e "${RED}Error: Unknown theme '$theme'${NC}"
        echo "Available themes: pacman-v2, pacman, vynx, vynx-official"
        exit 1
    fi
    
    if [ ! -d "$source" ]; then
        echo -e "${RED}Error: Theme directory '$source' does not exist!${NC}"
        exit 1
    fi
    
    echo -e "${YELLOW}• Switching theme to: ${GREEN}$theme${NC}..."
    ln -sf "$source" "$TARGET"
    
    echo -e "${YELLOW}• Refreshing Quickshell services...${NC}"
    if [ -f "$REFRESH_SCRIPT" ]; then
        bash "$REFRESH_SCRIPT" >/dev/null 2>&1
    else
        killall qs quickshell 2>/dev/null || :
        sleep 0.2
        nohup qs -c ii >/dev/null 2>&1 &
    fi
    
    echo -e "${GREEN}✓ Successfully switched to $theme!${NC}"
}

# Run switcher
if [ -z "$1" ]; then
    show_menu
else
    apply_theme "$1"
fi
