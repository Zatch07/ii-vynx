#!/usr/bin/env bash

REPO_DIR="$HOME/Documents/Branches/ii-zatch"

echo "🔄 Starting backup of dotfiles to ii-zatch repository..."
cd "$REPO_DIR" || { echo "❌ Failed to cd into $REPO_DIR"; exit 1; }

# Sync function to handle different backup targets
sync_target() {
    local source_dir="$1"
    local target_dir="$2"
    
    if [ ! -d "$target_dir" ]; then return; fi

    for item in "$target_dir"/*; do
        basename=$(basename "$item")
        if [ -d "$source_dir/$basename" ]; then
            if [ "$basename" == "quickshell" ]; then
                # Handle quickshell/ii specially since it's a symlink
                rsync -a --delete "$source_dir/quickshell/ii/" "$target_dir/quickshell/ii/"
                # Remove submodule .git to avoid nested git repo issues
                rm -rf "$target_dir/quickshell/ii/modules/common/widgets/shapes/.git"
            elif [ "$basename" == "vesktop" ]; then
                # Exclude session data, crash reports, and singletons for vesktop
                rsync -a --delete --exclude="sessionData" --exclude="Crashpad" --exclude="Singleton*" "$source_dir/vesktop/" "$target_dir/vesktop/"
            else
                rsync -a --delete "$source_dir/$basename/" "$target_dir/$basename/"
            fi
        elif [ -f "$source_dir/$basename" ]; then
            cp "$source_dir/$basename" "$target_dir/$basename"
        fi
    done
}

# 1. Sync .config
sync_target "$HOME/.config" "$REPO_DIR/dots/.config"

# 2. Sync .local/bin and .local/share if they exist
if [ -d "$REPO_DIR/dots/.local/bin" ]; then
    sync_target "$HOME/.local/bin" "$REPO_DIR/dots/.local/bin"
fi
if [ -d "$REPO_DIR/dots/.local/share" ]; then
    sync_target "$HOME/.local/share" "$REPO_DIR/dots/.local/share"
fi

# 3. Sync Pictures
# Sync Scripts inside Wallpapers
if [ -d "$HOME/Pictures/Wallpapers/Scripts" ]; then
    mkdir -p "$REPO_DIR/dots/Pictures/Wallpapers/Scripts"
    rsync -a --delete "$HOME/Pictures/Wallpapers/Scripts/" "$REPO_DIR/dots/Pictures/Wallpapers/Scripts/"
fi

# Ensure WallpaperEngine folder inside Wallpapers exists (without copying its contents)
if [ -d "$HOME/Pictures/Wallpapers/WallpaperEngine" ]; then
    mkdir -p "$REPO_DIR/dots/Pictures/Wallpapers/WallpaperEngine"
fi

# Sync 'Wallpaper Engine' folder and its contents
if [ -d "$HOME/Pictures/Wallpaper Engine" ]; then
    mkdir -p "$REPO_DIR/dots/Pictures/Wallpaper Engine"
    rsync -a --delete "$HOME/Pictures/Wallpaper Engine/" "$REPO_DIR/dots/Pictures/Wallpaper Engine/"
fi

echo "📁 Copied configuration files successfully."

# Make sure git tracks changes
git add dots/

# Check if there are changes to commit
if git diff --cached --quiet; then
    echo "✨ No new changes to backup."
else
    commit_msg="Backup dots: $(date +'%Y-%m-%d %H:%M:%S')"
    git commit -m "$commit_msg"
    echo "✅ Changes committed locally with message: '$commit_msg'"
    echo "🚀 You can now push these changes to GitHub using: cd $REPO_DIR && git push"
fi
